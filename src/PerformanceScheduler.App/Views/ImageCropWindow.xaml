<Window x:Class="PerformanceScheduler.App.Views.ImageCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="裁切图片"
        Width="920"
        Height="680"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            ResizeBorderThickness="8"
                            CornerRadius="12"
                            GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#F8FFFFFF"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="10">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="裁" />
                    </Border>
                    <TextBlock x:Name="WindowTitleText"
                               Grid.Column="1"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TitleBrush}"
                               Text="裁切图片" />
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Width="38"
                                Height="30"
                                Padding="0"
                                Margin="0,0,6,0"
                                Background="#FFEAF2FF"
                                BorderBrush="#FFD7E6FF"
                                Foreground="{DynamicResource AccentBrush}"
                                Content="－"
                                Click="MinimizeButton_Click" />
                        <Button Width="38"
                                Height="30"
                                Padding="0"
                                Margin="0"
                                Background="#FFFFEEF2"
                                BorderBrush="#FFFFCFDA"
                                Foreground="#FFC2464A"
                                Content="×"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Padding="18"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock x:Name="TitleText"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"
                                   Text="裁切侧栏图片" />
                        <TextBlock x:Name="InstructionText"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="拖动截选框选择显示区域，拖动四角可以调整范围。确认后会生成一张裁切后的预览图。" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,14,0,14"
                        Background="#FFEEF4FC"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        ClipToBounds="True">
                    <Canvas x:Name="CropCanvas"
                            Background="#FFEEF4FC"
                            ClipToBounds="True"
                            SizeChanged="CropCanvas_SizeChanged"
                            MouseMove="CropCanvas_MouseMove"
                            MouseLeftButtonUp="CropCanvas_MouseLeftButtonUp">
                        <Image x:Name="SourceImage"
                               Stretch="Fill"
                               IsHitTestVisible="False" />
                        <Path x:Name="OverlayPath"
                              Fill="#66000000"
                              IsHitTestVisible="False" />
                        <Border x:Name="CropFrame"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="2"
                                Background="#22FFFFFF"
                                Cursor="SizeAll"
                                MouseLeftButtonDown="CropFrame_MouseLeftButtonDown" />
                        <primitives:Thumb x:Name="TopLeftHandle"
                                          Width="16"
                                          Height="16"
                                          Cursor="SizeNWSE"
                                          DragDelta="Handle_DragDelta"
                                          Tag="TopLeft" />
                        <primitives:Thumb x:Name="TopRightHandle"
                                          Width="16"
                                          Height="16"
                                          Cursor="SizeNESW"
                                          DragDelta="Handle_DragDelta"
                                          Tag="TopRight" />
                        <primitives:Thumb x:Name="BottomLeftHandle"
                                          Width="16"
                                          Height="16"
                                          Cursor="SizeNESW"
                                          DragDelta="Handle_DragDelta"
                                          Tag="BottomLeft" />
                        <primitives:Thumb x:Name="BottomRightHandle"
                                          Width="16"
                                          Height="16"
                                          Cursor="SizeNWSE"
                                          DragDelta="Handle_DragDelta"
                                          Tag="BottomRight" />
                    </Canvas>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="FooterText"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Text="截选框比例会保持和当前区域一致，避免应用后变形。" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="ConfirmButton"
                                MinWidth="112"
                                Content="确认裁切"
                                Click="ConfirmButton_Click" />
                        <Button x:Name="CancelCropButton"
                                MinWidth="96"
                                Content="取消"
                                Background="#FFFFFFFF"
                                Foreground="{DynamicResource AccentBrush}"
                                BorderBrush="#FF9FC3FF"
                                BorderThickness="1"
                                Click="CancelCropButton_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
