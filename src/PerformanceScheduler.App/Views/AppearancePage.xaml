<UserControl x:Class="PerformanceScheduler.App.Views.AppearancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                Background="#F8FFFFFF"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               Text="{Binding Strings[Section.Appearance]}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TitleBrush}"
                               Text="{Binding Strings[Hint.AppearanceTitle]}" />
                    <TextBlock Margin="0,6,0,0"
                               MaxHeight="38"
                               FontSize="12"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding Strings[Hint.AppearanceIntro]}" />
                </StackPanel>
                <Border Grid.Column="1"
                        Width="54"
                        Height="54"
                        Margin="18,0,0,0"
                        Background="#FFEAF2FF"
                        CornerRadius="18">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Text="BG" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.92*" />
                <ColumnDefinition Width="1.08*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="18"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding Strings[Section.WindowBackground]}" />
                        <ComboBox Margin="0,10,0,0"
                                  ItemsSource="{Binding AppearanceBackgroundModeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding SelectedAppearanceBackgroundMode, Mode=TwoWay}" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <primitives:ToggleButton Grid.Column="0"
                                                     Style="{StaticResource ToggleSwitchStyle}"
                                                     IsChecked="{Binding AppearanceBackgroundImageEnabled, Mode=TwoWay}" />
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TitleBrush}"
                                           Text="{Binding Strings[Hint.AppearanceBackgroundToggleTitle]}" />
                                <TextBlock Margin="0,5,0,0"
                                           MaxHeight="32"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding Strings[Hint.AppearanceBackgroundToggleBody]}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,14,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TitleBrush}"
                                   Text="{Binding Strings[Section.BackgroundImagePath]}" />
                        <Border Margin="0,7,0,0"
                                Padding="10"
                                Background="#FFF8FBFF"
                                BorderBrush="#FFE2EAF5"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock MaxHeight="34"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding AppearanceBackgroundImageDisplayPath}" />
                        </Border>

                        <WrapPanel Margin="0,12,0,0">
                            <Button Padding="14,8"
                                    Content="{Binding Strings[Button.ChooseBackgroundImage]}"
                                    Command="{Binding ChooseAppearanceBackgroundCommand}" />
                            <Button Padding="14,8"
                                    Content="{Binding Strings[Button.ClearBackgroundImage]}"
                                    Command="{Binding ClearAppearanceBackgroundCommand}"
                                    Background="#FFFFFFFF"
                                    Foreground="{DynamicResource AccentBrush}"
                                    BorderBrush="#FF9FC3FF"
                                    BorderThickness="1" />
                            <Button Padding="14,8"
                                    Content="{Binding Strings[Button.OpenAppearanceAssetsDirectory]}"
                                    Command="{Binding OpenAppearanceAssetsDirectoryCommand}"
                                    Background="#FF4E7080" />
                        </WrapPanel>
                        <Border Margin="0,12,0,0"
                                Padding="10"
                                Background="#FFF8FBFF"
                                BorderBrush="#FFE2EAF5"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock MaxHeight="34"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding AppearanceSplitBackgroundSummary}" />
                        </Border>
                        <WrapPanel Margin="0,10,0,0">
                            <Button Padding="14,8"
                                    Content="{Binding Strings[Button.ChooseSidebarBackgroundImage]}"
                                    Command="{Binding ChooseAppearanceSidebarBackgroundCommand}" />
                            <Button Padding="14,8"
                                    Content="{Binding Strings[Button.ChooseContentBackgroundImage]}"
                                    Command="{Binding ChooseAppearanceContentBackgroundCommand}" />
                            <Button Padding="14,8"
                                    Content="{Binding Strings[Button.ClearRegionBackgroundImages]}"
                                    Command="{Binding ClearAppearanceRegionBackgroundsCommand}"
                                    Background="#FFFFFFFF"
                                    Foreground="{DynamicResource AccentBrush}"
                                    BorderBrush="#FF9FC3FF"
                                    BorderThickness="1" />
                        </WrapPanel>
                        <Border Margin="0,10,0,0"
                                Padding="12"
                                Background="#FFF8FBFF"
                                BorderBrush="#FFE2EAF5"
                                BorderThickness="1"
                                CornerRadius="14"
                                Visibility="{Binding AppearanceSidebarAdjustmentVisibility}">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="{Binding Strings[Section.SidebarImageAdjustment]}" />
                                <TextBlock Margin="0,4,0,0"
                                           MaxHeight="30"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding Strings[Hint.AppearanceSidebarAdjustment]}" />

                                <WrapPanel Margin="0,8,0,0">
                                    <Button Padding="12,7"
                                            Content="{Binding Strings[Button.ApplySidebarBackgroundPreview]}"
                                            Command="{Binding ApplyAppearanceSidebarBackgroundPreviewCommand}" />
                                    <Button Padding="12,7"
                                            Content="{Binding Strings[Button.CancelSidebarBackgroundPreview]}"
                                            Command="{Binding CancelAppearanceSidebarBackgroundPreviewCommand}"
                                            Background="#FFFFFFFF"
                                            Foreground="{DynamicResource AccentBrush}"
                                            BorderBrush="#FF9FC3FF"
                                            BorderThickness="1" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Margin="0,10,0,0"
                                Padding="12"
                                Background="#FFF8FBFF"
                                BorderBrush="#FFE2EAF5"
                                BorderThickness="1"
                                CornerRadius="14"
                                Visibility="{Binding AppearanceContentAdjustmentVisibility}">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="{Binding Strings[Section.ContentImageAdjustment]}" />
                                <TextBlock Margin="0,4,0,0"
                                           MaxHeight="30"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding Strings[Hint.AppearanceContentAdjustment]}" />

                                <WrapPanel Margin="0,8,0,0">
                                    <Button Padding="12,7"
                                            Content="{Binding Strings[Button.ApplyContentBackgroundPreview]}"
                                            Command="{Binding ApplyAppearanceContentBackgroundPreviewCommand}" />
                                    <Button Padding="12,7"
                                            Content="{Binding Strings[Button.CancelContentBackgroundPreview]}"
                                            Command="{Binding CancelAppearanceContentBackgroundPreviewCommand}"
                                            Background="#FFFFFFFF"
                                            Foreground="{DynamicResource AccentBrush}"
                                            BorderBrush="#FF9FC3FF"
                                            BorderThickness="1" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Padding="18"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding Strings[Section.ThemeAndReadability]}" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"
                                   Text="{Binding Strings[Hint.AppearanceThemeTitle]}" />
                        <TextBlock Margin="0,6,0,0"
                                   MaxHeight="30"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding Strings[Hint.AppearanceThemeBody]}" />
                        <ComboBox Margin="0,10,0,0"
                                  ItemsSource="{Binding AppearanceThemeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding SelectedAppearanceThemeKey, Mode=TwoWay}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TitleBrush}"
                                           Text="{Binding Strings[Section.InterfaceSurfaceColor]}" />
                                <TextBox Text="{Binding AppearanceSurfaceColorHex, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TitleBrush}"
                                           Text="{Binding Strings[Section.InterfaceBorderColor]}" />
                                <TextBox Text="{Binding AppearanceBorderColorHex, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Margin="0,6,0,0"
                                   MaxHeight="30"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding Strings[Hint.AppearanceColorFormat]}" />

                        <TextBlock Margin="0,12,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TitleBrush}"
                                   Text="{Binding Strings[Section.BackgroundStrength]}" />
                        <Slider Margin="0,7,0,0"
                                Minimum="0"
                                Maximum="1"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="False"
                                Value="{Binding AppearanceBackgroundImageOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TitleBrush}"
                                   Text="{Binding Strings[Section.WindowMaskStrength]}" />
                        <Slider Margin="0,7,0,0"
                                Minimum="0"
                                Maximum="0.98"
                                TickFrequency="0.02"
                                IsSnapToTickEnabled="False"
                                Value="{Binding AppearanceWindowOverlayOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,10,0,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TitleBrush}"
                                   Text="{Binding Strings[Section.CardTransparency]}" />
                        <Slider Margin="0,7,0,0"
                                Minimum="0.86"
                                Maximum="1"
                                TickFrequency="0.02"
                                IsSnapToTickEnabled="False"
                                Value="{Binding AppearanceCardOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,9,0,0"
                                   MaxHeight="28"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding AppearanceStatus}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Padding="16"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Margin="0,0,0,12">
                    <Border Background="#FFF5F9FF" CornerRadius="22" ClipToBounds="True">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                  Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Image Source="{Binding AppearanceBackgroundImagePath, Converter={StaticResource ImagePathToBitmapConverter}}"
                                       Stretch="UniformToFill"
                                       Opacity="{Binding AppearanceBackgroundImageOpacity}"
                                       Visibility="{Binding AppearanceBackgroundImageVisibility}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="232" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding AppearanceSidebarBackgroundPreviewPath, Converter={StaticResource ImagePathToBitmapConverter}}"
                                           Stretch="UniformToFill"
                                           Opacity="{Binding AppearanceBackgroundImageOpacity}"
                                           Visibility="{Binding AppearanceSidebarBackgroundPreviewVisibility}" />
                                    <Image Grid.Column="1"
                                           Source="{Binding AppearanceContentBackgroundPreviewPath, Converter={StaticResource ImagePathToBitmapConverter}}"
                                           Stretch="UniformToFill"
                                           Opacity="{Binding AppearanceBackgroundImageOpacity}"
                                           Visibility="{Binding AppearanceContentBackgroundPreviewVisibility}" />
                                    <Border Background="{Binding AppearanceSidebarOverlayBrush}" />
                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="66" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Background="{Binding AppearanceContentOverlayBrush}" />
                                        <Border Grid.Row="1" Background="{Binding AppearanceContentOverlayBrush}" />
                                    </Grid>
                                </Grid>
                                <StackPanel Margin="256,96,32,0">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Text="{Binding Strings[Section.AppearancePreview]}" />
                                    <TextBlock Margin="0,14,0,0"
                                               FontSize="36"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TitleBrush}"
                                               Text="{Binding Strings[Hint.AppearancePreviewTitle]}" />
                                    <TextBlock Margin="0,10,0,0"
                                               MaxWidth="640"
                                               FontSize="18"
                                               TextWrapping="Wrap"
                                               Text="{Binding Strings[Hint.AppearancePreviewBody]}" />
                                </StackPanel>
                            </Grid>
                        </Viewbox>
                    </Border>
                </Border>

                <Border Grid.Row="1"
                        Padding="18"
                        Background="#F8FFFFFF"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TitleBrush}"
                                   Text="{Binding Strings[Hint.AppearanceNextTitle]}" />
                        <TextBlock Margin="0,8,0,0"
                                   MaxHeight="42"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding Strings[Hint.AppearanceNextBody]}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
