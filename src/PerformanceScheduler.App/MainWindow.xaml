
<Window x:Class="PerformanceScheduler.App.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:models="clr-namespace:PerformanceScheduler.Core.Models;assembly=PerformanceScheduler.Core"
 xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
 xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
 xmlns:ui="clr-namespace:PerformanceScheduler.App.Ui"
 xmlns:viewModels="clr-namespace:PerformanceScheduler.App.ViewModels"
 xmlns:views="clr-namespace:PerformanceScheduler.App.Views"
 mc:Ignorable="d"
 Title="{Binding Strings[App.Title]}" Width="1440" Height="900" MinWidth="1220" MinHeight="760" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize">
 <shell:WindowChrome.WindowChrome>
  <shell:WindowChrome CaptionHeight="66" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
 </shell:WindowChrome.WindowChrome>
 <Grid>
  <Grid.Background>
   <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#FFFFFFFF" Offset="0"/>
    <GradientStop Color="#FFF6F9FE" Offset="0.58"/>
   <GradientStop Color="#FFEFF5FF" Offset="1"/>
   </LinearGradientBrush>
  </Grid.Background>
  <Image Source="{Binding AppearanceBackgroundImagePath, Converter={StaticResource ImagePathToBitmapConverter}}" Stretch="UniformToFill" Opacity="{Binding AppearanceBackgroundImageOpacity}" Visibility="{Binding AppearanceBackgroundImageVisibility}" IsHitTestVisible="False"/>
  <Border Margin="0" Padding="0" Background="{Binding AppearanceWindowOverlayBrush}" BorderBrush="#FFE3EAF4" BorderThickness="1" CornerRadius="0">
   <TabControl Background="Transparent" BorderThickness="0" TabStripPlacement="Left">
    <TabControl.Resources>
     <Style x:Key="SidebarTabItemStyle" TargetType="TabItem">
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Padding" Value="16,14"/>
      <Setter Property="Foreground" Value="{StaticResource SidebarMutedBrush}"/>
      <Setter Property="Template">
       <Setter.Value>
        <ControlTemplate TargetType="TabItem">
         <Border x:Name="ItemBorder" Margin="{TemplateBinding Margin}" Padding="{TemplateBinding Padding}" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" CornerRadius="14">
          <ContentPresenter ContentSource="Header"/>
         </Border>
         <ControlTemplate.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
           <Setter TargetName="ItemBorder" Property="Background" Value="#FFF1F6FF"/>
           <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
          </Trigger>
          <Trigger Property="IsSelected" Value="True">
           <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SidebarSelectedBrush}"/>
           <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#FFBBD5FF"/>
           <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
          </Trigger>
         </ControlTemplate.Triggers>
        </ControlTemplate>
       </Setter.Value>
      </Setter>
     </Style>
     <Style TargetType="TabItem" BasedOn="{StaticResource SidebarTabItemStyle}"/>
     <Style x:Key="WindowControlButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="38"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="#FFEAF2FF"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="BorderBrush" Value="#FFB8D2FF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
      <Setter Property="Template">
       <Setter.Value>
        <ControlTemplate TargetType="Button">
         <Border x:Name="WindowButtonSurface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Foreground="{TemplateBinding Foreground}" Text="{TemplateBinding Content}"/>
         </Border>
         <ControlTemplate.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
           <Setter TargetName="WindowButtonSurface" Property="Background" Value="{DynamicResource AccentBrush}"/>
           <Setter TargetName="WindowButtonSurface" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
           <Setter Property="Foreground" Value="White"/>
          </Trigger>
          <Trigger Property="IsPressed" Value="True">
           <Setter TargetName="WindowButtonSurface" Property="Background" Value="#FF155EE0"/>
           <Setter TargetName="WindowButtonSurface" Property="BorderBrush" Value="#FF155EE0"/>
          </Trigger>
         </ControlTemplate.Triggers>
        </ControlTemplate>
       </Setter.Value>
      </Setter>
     </Style>
     <Style x:Key="CloseWindowButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
      <Setter Property="Background" Value="#FFFFEDF0"/>
      <Setter Property="Foreground" Value="#FFD64045"/>
      <Setter Property="BorderBrush" Value="#FFFFC4CC"/>
      <Style.Triggers>
       <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#FFD64045"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#FFD64045"/>
       </Trigger>
      </Style.Triggers>
     </Style>
     <Style x:Key="LanguageSwitchButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="150"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Margin" Value="0,7,0,0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="#FFFFFFFF"/>
      <Setter Property="Foreground" Value="{StaticResource TitleBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
      <Setter Property="RenderTransform">
       <Setter.Value>
        <TranslateTransform/>
       </Setter.Value>
      </Setter>
      <Setter Property="Template">
       <Setter.Value>
        <ControlTemplate TargetType="Button">
         <Border x:Name="LanguageButtonSurface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" SnapsToDevicePixels="True">
          <Grid ClipToBounds="True">
           <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
           <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{TemplateBinding Foreground}" Text="{Binding DataContext.SelectedLanguage.DisplayName, RelativeSource={RelativeSource AncestorType=Window}}"/>
           <Border Grid.Column="1" Width="20" Height="20" Background="#FFEAF2FF" CornerRadius="10">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="↕"/>
           </Border>
          </Grid>
         </Border>
         <ControlTemplate.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
           <Setter TargetName="LanguageButtonSurface" Property="Background" Value="#FFF6FAFF"/>
           <Setter TargetName="LanguageButtonSurface" Property="BorderBrush" Value="#FFBFD8FF"/>
          </Trigger>
          <Trigger Property="IsPressed" Value="True">
           <Setter TargetName="LanguageButtonSurface" Property="Background" Value="#FFEAF2FF"/>
          </Trigger>
         </ControlTemplate.Triggers>
        </ControlTemplate>
       </Setter.Value>
      </Setter>
     </Style>
    </TabControl.Resources>
    <TabControl.Template>
     <ControlTemplate TargetType="TabControl">
      <Grid>
       <Grid.ColumnDefinitions><ColumnDefinition Width="232"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
       <Border Grid.Column="0" Padding="18,20" Background="Transparent" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
        <Grid>
         <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <Image Grid.RowSpan="4" Source="{Binding AppearanceSidebarBackgroundImagePath, Converter={StaticResource ImagePathToBitmapConverter}}" Stretch="UniformToFill" Opacity="{Binding AppearanceBackgroundImageOpacity}" Visibility="{Binding AppearanceSidebarBackgroundImageVisibility}" IsHitTestVisible="False"/>
          <Border Grid.RowSpan="4" Background="{Binding AppearanceSidebarOverlayBrush}" IsHitTestVisible="False"/>
          <StackPanel>
           <StackPanel Orientation="Horizontal">
            <Border Width="42" Height="42" Background="{StaticResource AccentBrush}" CornerRadius="12" HorizontalAlignment="Left"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="White" Text="芯"/></Border>
            <TextBlock Margin="12,4,0,0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SidebarTextBrush}" Text="{Binding DataContext.Strings[App.Title], RelativeSource={RelativeSource TemplatedParent}}"/>
           </StackPanel>
           <TextBlock Margin="0,12,0,0" MaxHeight="50" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Foreground="{StaticResource SidebarMutedBrush}" Text="{Binding DataContext.Strings[App.Subtitle], RelativeSource={RelativeSource TemplatedParent}}"/>
          </StackPanel>
          <StackPanel Grid.Row="1" Margin="0,18,0,0">
           <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SidebarTextBrush}" Text="{Binding DataContext.Strings[App.Language], RelativeSource={RelativeSource TemplatedParent}}"/>
           <Button Style="{StaticResource LanguageSwitchButtonStyle}" Click="LanguageSwitchButton_Click"/>
           <Border Margin="0,14,0,0" Padding="12" Background="{StaticResource SidebarSurfaceBrush}" BorderBrush="{StaticResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="16">
            <StackPanel>
             <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SidebarTextBrush}" Text="{Binding DataContext.Strings[Section.NavigationGlance], RelativeSource={RelativeSource TemplatedParent}}"/>
             <WrapPanel Margin="0,10,0,0">
              <Border Margin="0,0,8,8" Padding="10,4" Background="#FFEAF2FF" CornerRadius="999"><TextBlock Foreground="{StaticResource AccentBrush}" Text="{Binding DataContext.NavigationNoticesSummary, RelativeSource={RelativeSource TemplatedParent}}"/></Border>
              <Border Margin="0,0,8,8" Padding="10,4" Background="#FFF1F6FF" CornerRadius="999"><TextBlock Foreground="{StaticResource TitleBrush}" Text="{Binding DataContext.NavigationProfilesSummary, RelativeSource={RelativeSource TemplatedParent}}"/></Border>
              <Border Margin="0,0,8,8" Padding="10,4" Background="#FFFFF4E2" CornerRadius="999"><TextBlock Foreground="#FF9B6A18" Text="{Binding DataContext.NavigationCommunitySummary, RelativeSource={RelativeSource TemplatedParent}}"/></Border>
             </WrapPanel>
            </StackPanel>
           </Border>
          </StackPanel>
          <ScrollViewer Grid.Row="2" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
           <TabPanel IsItemsHost="True" Background="Transparent"/>
          </ScrollViewer>
          <Border Grid.Row="3" Margin="0,10,0,0" Padding="12" MaxHeight="116" Background="{StaticResource SidebarSurfaceBrush}" BorderBrush="{StaticResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="16">
           <StackPanel>
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SidebarTextBrush}" Text="{Binding DataContext.Strings[Section.RuntimeStatus], RelativeSource={RelativeSource TemplatedParent}}"/>
            <TextBlock Margin="0,8,0,0" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{StaticResource SidebarTextBrush}" Text="{Binding DataContext.MonitoringModeSummary, RelativeSource={RelativeSource TemplatedParent}}"/>
            <TextBlock Margin="0,6,0,0" MaxHeight="34" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Foreground="{StaticResource SidebarMutedBrush}" Text="{Binding DataContext.MonitoringStatus, RelativeSource={RelativeSource TemplatedParent}}"/>
            <TextBlock Margin="0,8,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource SidebarMutedBrush}" Text="{Binding DataContext.LastRefreshTime, RelativeSource={RelativeSource TemplatedParent}}"/>
           </StackPanel>
          </Border>
        </Grid>
       </Border>
       <Grid Grid.Column="1">
        <Grid.RowDefinitions><RowDefinition Height="66"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="24,0,10,0" Background="#FAFFFFFF" BorderBrush="#FFE7EEF7" BorderThickness="0,0,0,1">
         <Grid VerticalAlignment="Center">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="230"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <Border Grid.Column="1" Height="40" Padding="16,0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="20" shell:WindowChrome.IsHitTestVisibleInChrome="True">
           <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock FontSize="17" Foreground="{StaticResource AccentBrush}" Text="⌕"/>
            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource SidebarMutedBrush}" Text="{Binding DataContext.Strings[Hint.SearchAppOrConfig], RelativeSource={RelativeSource TemplatedParent}}"/>
           </StackPanel>
          </Border>
          <Border Grid.Column="2" Margin="16,0,0,0" Height="40" Padding="14,0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" shell:WindowChrome.IsHitTestVisibleInChrome="True">
           <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock FontSize="15" Foreground="{StaticResource AccentBrush}" Text="▣"/>
            <TextBlock Margin="9,0,0,0" MaxWidth="170" TextTrimming="CharacterEllipsis" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding DataContext.DeviceFingerprintSummary, RelativeSource={RelativeSource TemplatedParent}}"/>
           </StackPanel>
          </Border>
          <StackPanel Grid.Column="3" Margin="16,0,0,0" Orientation="Horizontal" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
           <Ellipse Width="10" Height="10" Fill="#FF24C45A"/>
           <TextBlock Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding DataContext.MonitoringModeSummary, RelativeSource={RelativeSource TemplatedParent}}"/>
          </StackPanel>
          <Border Grid.Column="4" Margin="16,0,12,0" Width="40" Height="40" Background="#FFF1F5FB" CornerRadius="20" shell:WindowChrome.IsHitTestVisibleInChrome="True">
           <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="17" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="{Binding DataContext.StatusCenterCount, RelativeSource={RelativeSource TemplatedParent}}"/>
          </Border>
          <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
           <Button Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeWindow_Click" Content="━"/>
           <Button Style="{StaticResource WindowControlButtonStyle}" Click="ToggleMaximizeWindow_Click" Content="□"/>
           <Button Style="{StaticResource CloseWindowButtonStyle}" Click="CloseWindow_Click" Content="×"/>
          </StackPanel>
         </Grid>
        </Border>
        <Grid Grid.Row="1">
         <Image Source="{Binding AppearanceContentBackgroundImagePath, Converter={StaticResource ImagePathToBitmapConverter}}" Stretch="UniformToFill" Opacity="{Binding AppearanceBackgroundImageOpacity}" Visibility="{Binding AppearanceContentBackgroundImageVisibility}" IsHitTestVisible="False"/>
         <Border Background="{Binding AppearanceContentOverlayBrush}"><ContentPresenter ContentSource="SelectedContent"/></Border>
        </Grid>
       </Grid>
      </Grid>
     </ControlTemplate>
    </TabControl.Template>
    <TabItem>
     <TabItem.Header>
      <StackPanel>
       <DockPanel>
        <TextBlock DockPanel.Dock="Left" FontSize="17" FontWeight="SemiBold" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Text="{Binding DataContext.Strings[Nav.OverviewTitle], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <Border DockPanel.Dock="Right" Margin="12,0,0,0" Padding="8,2" Background="#1EFFFFFF" CornerRadius="999"><TextBlock FontSize="11" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Text="{Binding DataContext.StatusCenterCount, RelativeSource={RelativeSource AncestorType=Window}}"/></Border>
       </DockPanel>
       <TextBlock Margin="0,5,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Opacity="0.78" Text="{Binding DataContext.Strings[Nav.OverviewDescription], RelativeSource={RelativeSource AncestorType=Window}}"/>
      </StackPanel>
     </TabItem.Header>
     <Grid Margin="18">
       <Grid.RowDefinitions><RowDefinition Height="0.62*"/><RowDefinition Height="1.1*"/><RowDefinition Height="0.86*"/></Grid.RowDefinitions>
       <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="1.55*"/><ColumnDefinition Width="0.85*"/><ColumnDefinition Width="0.95*"/></Grid.ColumnDefinitions>
        <Border Margin="0,0,14,12" Padding="14" Style="{StaticResource CardStyle}" Background="#FFFFFFFF">
         <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="78"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <Border Width="60" Height="60" Background="#FFEAF2FF" CornerRadius="18" HorizontalAlignment="Left" VerticalAlignment="Center">
           <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="App"/>
          </Border>
          <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center">
           <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Section.ForegroundTarget]}"/>
           <TextBlock Margin="0,5,0,0" FontSize="19" FontWeight="Bold" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TitleBrush}" Text="{Binding FocusedAppName}"/>
           <TextBlock Margin="0,4,0,0" MaxHeight="30" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Text="{Binding FocusedAppDetails}"/>
           <Border Margin="0,6,0,0" Padding="9,4" HorizontalAlignment="Left" Background="#FFE7F8EC" CornerRadius="10">
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#FF149A48" Text="{Binding ClassificationSummary}"/>
           </Border>
          </StackPanel>
         </Grid>
        </Border>
        <Border Grid.Column="1" Margin="0,0,14,12" Padding="14" Style="{StaticResource CardStyle}" Background="#FFFFFFFF">
         <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <DockPanel>
           <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Section.QuickActions]}"/>
           <primitives:ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding IsMonitoringRunning, Mode=OneWay}" Command="{Binding ToggleMonitoringCommand}" IsEnabled="{Binding CanToggleMonitoring}"/>
          </DockPanel>
          <Grid Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center">
           <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
           <Border Width="40" Height="40" Background="#FFEAF2FF" CornerRadius="20" HorizontalAlignment="Left">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="✓"/>
           </Border>
           <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock FontSize="15" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TitleBrush}" Text="{Binding MonitoringToggleButtonText}"/>
            <TextBlock Margin="0,4,0,0" MaxHeight="30" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Text="{Binding MonitoringStatus}"/>
           </StackPanel>
          </Grid>
         </Grid>
        </Border>
        <Border Grid.Column="2" Margin="0,0,0,12" Padding="14" Style="{StaticResource CardStyle}" Background="#FFFFFFFF">
         <StackPanel VerticalAlignment="Center">
          <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Button.Rollback]}"/>
          <Border Margin="0,10,0,0" Width="46" Height="46" Background="#FFEAF2FF" CornerRadius="23" HorizontalAlignment="Left">
           <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" Foreground="{StaticResource AccentBrush}" Text="↶"/>
          </Border>
          <TextBlock Margin="0,7,0,0" MaxHeight="30" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Text="{Binding Strings[Hint.RollbackCard]}"/>
          <Button Margin="0,8,0,0" Padding="14,7" Content="{Binding Strings[Button.Rollback]}" Command="{Binding RestoreCommand}" Background="#FFFFFFFF" Foreground="{StaticResource AccentBrush}" BorderBrush="#FF9FC3FF" BorderThickness="1"/>
         </StackPanel>
        </Border>
       </Grid>
       <Border Grid.Row="1" Margin="0,0,0,12" Padding="16" Style="{StaticResource CardStyle}" Background="#FFFFFFFF" BorderBrush="#FFBFD8FF">
        <StackPanel>
         <StackPanel Orientation="Horizontal">
          <TextBlock Margin="0,0,12,0" FontSize="22" Foreground="{StaticResource AccentBrush}" Text="⌁"/>
          <StackPanel>
           <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.CurrentSchedulingState]}"/>
           <TextBlock Margin="0,6,0,0" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding LastSummary}"/>
          </StackPanel>
         </StackPanel>
         <UniformGrid Margin="0,12,0,0" Columns="3">
          <Border Margin="0,0,12,0" Padding="14" Background="#FFF6FAFF" BorderBrush="#FFE0ECFF" BorderThickness="1" CornerRadius="18">
           <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Width="34" Height="34" Background="#FFEAF2FF" CornerRadius="11">
             <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="19" Foreground="{StaticResource AccentBrush}" Text="⊞"/>
            </Border>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
             <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SidebarMutedBrush}" Text="{Binding Strings[Section.MatchedProfile]}"/>
             <TextBlock Margin="0,5,0,0" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TitleBrush}" Text="{Binding MatchedProfileName}"/>
             <TextBlock Margin="0,5,0,0" MaxHeight="30" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Text="{Binding ProfileReason}"/>
            </StackPanel>
           </Grid>
          </Border>
          <Border Margin="6,0,6,0" Padding="14" Background="#FFF3FBF6" BorderBrush="#FFDFF3E8" BorderThickness="1" CornerRadius="18">
           <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Width="34" Height="34" Background="#FFE4F5E8" CornerRadius="11">
             <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="19" Foreground="#FF20A856" Text="◒"/>
            </Border>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
             <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SidebarMutedBrush}" Text="{Binding Strings[Section.PowerPlan]}"/>
             <TextBlock Margin="0,5,0,0" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TitleBrush}" Text="{Binding ActivePowerPlanName}"/>
            </StackPanel>
           </Grid>
          </Border>
          <Border Margin="12,0,0,0" Padding="14" Background="#FFF8F4FF" BorderBrush="#FFE9DEFF" BorderThickness="1" CornerRadius="18">
           <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Width="34" Height="34" Background="#FFF2E9FF" CornerRadius="11">
             <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="19" Foreground="#FF8557D8" Text="≡"/>
            </Border>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
             <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SidebarMutedBrush}" Text="{Binding Strings[Section.Priority]}"/>
             <TextBlock Margin="0,5,0,0" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TitleBrush}" Text="{Binding PrioritySummary}"/>
            </StackPanel>
           </Grid>
          </Border>
         </UniformGrid>
         <UniformGrid Margin="0,10,0,0" Columns="3">
          <Border Margin="0,0,10,0" Padding="12" Background="#FFF9FCFF" BorderBrush="#FFE4ECF7" BorderThickness="1" CornerRadius="16">
           <StackPanel>
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SidebarMutedBrush}" Text="{Binding Strings[Section.BasicMetrics]}"/>
            <TextBlock Margin="0,8,0,0" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TitleBrush}" Text="{Binding MetricsSummary}"/>
           </StackPanel>
          </Border>
          <Border Margin="4,0,6,0" Padding="12" Background="#FFFFFBF3" BorderBrush="#FFFFEDD2" BorderThickness="1" CornerRadius="16">
           <StackPanel>
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#FF9B6A18" Text="{Binding Strings[Section.LastScan]}"/>
            <TextBlock Margin="0,8,0,0" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TitleBrush}" Text="{Binding LastRefreshTime}"/>
           </StackPanel>
          </Border>
          <Border Margin="6,0,4,0" Padding="12" Background="#FFF7FBF8" BorderBrush="#FFE0F0E6" BorderThickness="1" CornerRadius="16">
           <StackPanel>
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#FF2F7B5A" Text="{Binding Strings[Section.StorageOverview]}"/>
            <TextBlock Margin="0,8,0,0" MaxHeight="34" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TitleBrush}" Text="{Binding StorageSummary}"/>
           </StackPanel>
          </Border>
         </UniformGrid>
        </StackPanel>
