          <Border.Style><Style TargetType="Border"><Setter Property="BorderBrush" Value="#FFE0E8EC"/><Setter Property="BorderThickness" Value="1"/><Style.Triggers><DataTrigger Binding="{Binding ProfileDraft.HasBackgroundPolicyIssues}" Value="True"><Setter Property="BorderBrush" Value="{StaticResource ValidationBrush}"/><Setter Property="BorderThickness" Value="2"/></DataTrigger></Style.Triggers></Style></Border.Style>
          <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
           <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Section.BackgroundPolicies]}"/><TextBlock Margin="0,4,0,0" FontSize="12" Text="{Binding Strings[Hint.BackgroundPolicies]}"/></StackPanel><Button Grid.Column="1" Content="{Binding Strings[Button.AddPolicy]}" Command="{Binding AddBackgroundPolicyCommand}" Background="#FF1F7A5C"/></Grid>
           <ItemsControl Grid.Row="1" Margin="0,14,0,0" ItemsSource="{Binding ProfileDraft.BackgroundPolicies}">
            <ItemsControl.ItemTemplate>
             <DataTemplate DataType="{x:Type viewModels:BackgroundPolicyDraftItemViewModel}">
              <Border Margin="0,0,0,10" Padding="12" Background="White" BorderBrush="#FFE2E8EC" BorderThickness="1" CornerRadius="12">
               <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,10,0"><TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding DataContext.Strings[Section.Category], RelativeSource={RelativeSource AncestorType=Window}}"/><ComboBox ItemsSource="{Binding DataContext.BackgroundPolicyCategoryOptions, RelativeSource={RelativeSource AncestorType=Window}}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,10,0"><TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding DataContext.Strings[Section.TargetPriority], RelativeSource={RelativeSource AncestorType=Window}}"/><ComboBox ItemsSource="{Binding DataContext.PriorityOptions, RelativeSource={RelativeSource AncestorType=Window}}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding TargetPriority, Mode=TwoWay}"/></StackPanel>
                <Button Grid.Column="2" VerticalAlignment="Bottom" Content="{Binding DataContext.Strings[Button.Remove], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.RemoveBackgroundPolicyCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="#FF8A3B49"/>
                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0"><CheckBox Content="{Binding DataContext.Strings[Hint.PreferEfficiencyMode], RelativeSource={RelativeSource AncestorType=Window}}" IsChecked="{Binding PreferEfficiencyMode, Mode=TwoWay}"/><TextBlock Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" Text="{Binding DataContext.Strings[Section.Notes], RelativeSource={RelativeSource AncestorType=Window}}"/><TextBox MinHeight="64" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
               </Grid>
              </Border>
             </DataTemplate>
            </ItemsControl.ItemTemplate>
           </ItemsControl>
          </Grid>
         </Border>
         <Border Margin="0,14,0,0" Padding="14" Background="#FFF6F8FD" BorderBrush="#FFDCE3F2" BorderThickness="1" CornerRadius="14">
          <Border.Style><Style TargetType="Border"><Setter Property="BorderBrush" Value="#FFDCE3F2"/><Setter Property="BorderThickness" Value="1"/><Style.Triggers><DataTrigger Binding="{Binding ProfileDraft.HasGpuIssues}" Value="True"><Setter Property="BorderBrush" Value="{StaticResource ValidationBrush}"/><Setter Property="BorderThickness" Value="2"/></DataTrigger></Style.Triggers></Style></Border.Style>
          <StackPanel>
           <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Section.GpuStrategy]}"/>
           <TextBlock Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap" Text="{Binding Strings[Hint.GpuStrategy]}"/>
           <Border Margin="0,12,0,0" Padding="12" Background="#FFFFFFFF" BorderBrush="#FFE1E6F0" BorderThickness="1" CornerRadius="12">
            <StackPanel>
             <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#FF4E65A8" Text="{Binding GpuAdapterSummary}"/>
             <TextBlock Margin="0,6,0,0" FontSize="12" TextWrapping="Wrap" Text="{Binding GpuCapabilitySummary}"/>
            </StackPanel>
           </Border>
           <Grid Margin="0,14,0,0" IsEnabled="False"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.9*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,10,0"><TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Strings[Section.GpuMode]}"/><ComboBox ItemsSource="{Binding GpuModeOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ProfileDraft.GpuMode, Mode=TwoWay}"/></StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,10,0"><TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Strings[Section.GpuClockLimit]}"/><TextBox Text="{Binding ProfileDraft.GpuMaxCoreClockMHzText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/></StackPanel>
            <StackPanel Grid.Column="2" Margin="10,0,0,0"><TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Strings[Section.GpuVoltageOffset]}"/><TextBox Text="{Binding ProfileDraft.GpuVoltageOffsetMvText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/></StackPanel>
           </Grid>
           <CheckBox Margin="0,12,0,0" Content="{Binding Strings[Hint.GpuVendorApi]}" IsChecked="{Binding ProfileDraft.GpuAllowVendorApi, Mode=TwoWay}" IsEnabled="False"/>
           <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Hint.GpuStrategyPlanned]}"/>
          </StackPanel>
         </Border>
         <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.8*"/></Grid.ColumnDefinitions>
          <StackPanel Margin="0,0,12,0"><TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Section.Notes]}"/><TextBox MinHeight="160" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding ProfileDraft.Notes, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
          <StackPanel Grid.Column="1" Margin="12,0,0,0"><TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Section.Validation]}"/><TextBlock Margin="0,6,0,0" FontSize="12" Text="{Binding ValidationSummary}"/>
           <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ValidationIssues}"><ItemsControl.ItemTemplate><DataTemplate><Border Margin="0,0,0,8" Padding="8" Background="#FFFFF4E8" CornerRadius="10"><TextBlock FontSize="12" TextWrapping="Wrap" Text="{Binding}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
           <TextBlock Margin="0,12,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Section.RevisionHistory]}"/>
           <ListBox Margin="0,8,0,0" Height="170" ItemsSource="{Binding ProfileHistory}" SelectedItem="{Binding SelectedProfileRevision, Mode=TwoWay}">
            <ListBox.ItemTemplate><DataTemplate DataType="{x:Type models:ProfileRevisionInfo}"><Border Margin="0,0,0,8" Padding="10" Background="#FFF7FAFB" BorderBrush="#FFE1E8EC" BorderThickness="1" CornerRadius="10"><StackPanel><TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding DisplayName}"/><TextBlock Margin="0,4,0,0" FontSize="11" Text="{Binding Profile.Notes}" TextTrimming="CharacterEllipsis"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
           </ListBox>
          </StackPanel>
         </Grid>
        </StackPanel></Border>
       </Grid>
      </Grid>
     </ScrollViewer>
    </TabItem>
    <TabItem>
     <TabItem.Header><StackPanel><TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Text="{Binding DataContext.Strings[Nav.DiagnosticsTitle], RelativeSource={RelativeSource AncestorType=Window}}"/><TextBlock Margin="0,5,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Opacity="0.78" Text="{Binding DataContext.Strings[Nav.DiagnosticsDescription], RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></TabItem.Header>
     <ScrollViewer VerticalScrollBarVisibility="Auto">
      <Grid Margin="28"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
       <UniformGrid Columns="4" Margin="0,0,0,20"><Border Margin="0,0,14,0" Style="{StaticResource CardStyle}" Background="#FFF8FBFD"><StackPanel><TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.RuntimeStatus]}"/><TextBlock Margin="0,10,0,0" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="{Binding MonitoringModeSummary}"/><TextBlock Margin="0,8,0,0" FontSize="13" TextWrapping="Wrap" Text="{Binding MonitoringStatus}"/><TextBlock Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap" Text="{Binding LastRefreshTime}"/></StackPanel></Border><Border Margin="0,0,14,0" Style="{StaticResource CardStyle}" Background="#FFF7FAFB"><StackPanel><TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.Storage]}"/><TextBlock Margin="0,10,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="{Binding StorageSummary}"/></StackPanel></Border><Border Margin="0,0,14,0" Style="{StaticResource CardStyle}" Background="#FFF6F8FD"><StackPanel><TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#FF4E65A8" Text="{Binding Strings[Section.GpuReadiness]}"/><TextBlock Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="{Binding GpuAdapterSummary}"/><TextBlock Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap" Text="{Binding GpuCapabilitySummary}"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Background="#FFF3FAFE"><StackPanel><TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#FF277EA3" Text="{Binding Strings[Section.DeviceFingerprint]}"/><TextBlock Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TitleBrush}" Text="{Binding DeviceFingerprintSummary}"/></StackPanel></Border></UniformGrid>
       <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="0.9*"/><ColumnDefinition Width="1.4*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Margin="0,0,9,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.CapabilityDetector]}"/><ItemsControl Margin="0,16,0,0" ItemsSource="{Binding CapabilityLines}"><ItemsControl.ItemTemplate><DataTemplate><Border Margin="0,0,0,10" Padding="12" Background="#FFF5F8FA" CornerRadius="12"><TextBlock FontSize="13" TextWrapping="Wrap" Text="{Binding}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
        <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource CardStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.RecentLogs]}"/><TextBlock Margin="12,0,0,0" FontSize="12" Text="{Binding LastRefreshTime}"/></StackPanel><ListBox Grid.Row="1" Margin="0,16,0,0" ItemsSource="{Binding RecentLogs}"><ListBox.ItemTemplate><DataTemplate DataType="{x:Type models:LogEntry}"><Border Margin="0,0,0,10" Padding="12" Background="#FFF8FAFB" BorderBrush="#FFE3E8EC" BorderThickness="1" CornerRadius="12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock FontFamily="Consolas" Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"/><TextBlock Grid.Column="1" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Level}"/><TextBlock Grid.Column="2" TextWrapping="Wrap" Text="{Binding Message}"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></Border>
       </Grid>
      </Grid>
     </ScrollViewer>
    </TabItem>
    <TabItem>
     <TabItem.Header><StackPanel><TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Text="{Binding DataContext.Strings[Nav.AppearanceTitle], RelativeSource={RelativeSource AncestorType=Window}}"/><TextBlock Margin="0,5,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Opacity="0.78" Text="{Binding DataContext.Strings[Nav.AppearanceDescription], RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></TabItem.Header>
     <views:AppearancePage/>
    </TabItem>
    <TabItem>
     <TabItem.Header><StackPanel><TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Text="{Binding DataContext.Strings[Nav.SettingsTitle], RelativeSource={RelativeSource AncestorType=Window}}"/><TextBlock Margin="0,5,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Opacity="0.78" Text="{Binding DataContext.Strings[Nav.SettingsDescription], RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></TabItem.Header>
     <ScrollViewer VerticalScrollBarVisibility="Auto">
      <Grid Margin="28">
       <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
       <Border Style="{StaticResource CardStyle}" Background="#FFF9FCFD">
        <StackPanel>
         <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.Settings]}"/>
         <TextBlock Margin="0,10,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="{Binding MonitoringStatus}"/>
         <TextBlock Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap" Text="{Binding Strings[Hint.SettingsApplyNextLaunch]}"/>
         <StackPanel Margin="0,14,0,0" Width="260" HorizontalAlignment="Left">
          <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Section.MonitoringInterval]}"/>
          <ComboBox ItemsSource="{Binding MonitoringIntervalOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding MonitoringIntervalSeconds, Mode=TwoWay}"/>
          <TextBlock Margin="0,8,0,0" FontSize="12" TextWrapping="Wrap" Text="{Binding Strings[Hint.MonitoringInterval]}"/>
         </StackPanel>
         <WrapPanel Margin="0,14,0,0">
          <StackPanel Margin="0,0,18,10">
           <primitives:ToggleButton Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding IsMonitoringRunning, Mode=OneWay}" Command="{Binding ToggleMonitoringCommand}" IsEnabled="{Binding CanToggleMonitoring}"/>
           <TextBlock Width="160" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding MonitoringToggleButtonText}"/>
          </StackPanel>
          <Button Content="{Binding Strings[Button.Rollback]}" Command="{Binding RestoreCommand}" Background="#FF8A3B49"/>
         </WrapPanel>
         <Border Margin="0,12,0,0" Padding="14" Background="#FFFFFFFF" BorderBrush="#FFE1EAF7" BorderThickness="1" CornerRadius="16">
          <Grid>
           <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions>
           <primitives:ToggleButton Grid.Column="0" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding LanguageTransitionAnimationEnabled, Mode=TwoWay}"/>
           <StackPanel Grid.Column="1" Margin="8,0,18,0">
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.LanguageAnimationSettings]}"/>
            <TextBlock Margin="0,6,0,0" FontSize="12" TextWrapping="Wrap" Text="{Binding Strings[Hint.LanguageTransitionAnimationEnabled]}"/>
           </StackPanel>
           <StackPanel Grid.Column="2">
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Hint.LanguageTransitionDurationSeconds]}"/>
            <TextBox Width="110" Text="{Binding LanguageTransitionDurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=150, ValidatesOnExceptions=True}"/>
           </StackPanel>
          </Grid>
         </Border>
        </StackPanel>
       </Border>
       <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,20">
        <Border Margin="0,0,14,0" Style="{StaticResource CardStyle}" Background="#FFF7FAFB">
         <StackPanel>
          <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.SafetySettings]}"/>
          <DockPanel Margin="0,12,0,0"><primitives:ToggleButton DockPanel.Dock="Left" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding PauseSchedulingAfterUnsafeExit, Mode=TwoWay}"/><TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Strings[Hint.PauseSchedulingAfterUnsafeExit]}"/></DockPanel>
          <DockPanel Margin="0,10,0,0"><primitives:ToggleButton DockPanel.Dock="Left" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding AutoRollbackOnUnsafeExit, Mode=TwoWay}"/><TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Strings[Hint.AutoRollbackOnUnsafeExit]}"/></DockPanel>
          <DockPanel Margin="0,10,0,0"><primitives:ToggleButton DockPanel.Dock="Left" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding DisableProfileAfterRepeatedUnsafeRuns, Mode=TwoWay}"/><TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Strings[Hint.DisableProfileAfterRepeatedUnsafeRuns]}"/></DockPanel>
          <StackPanel Margin="0,14,0,0">
           <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TitleBrush}" Text="{Binding Strings[Hint.UnsafeRunThreshold]}"/>
           <TextBox Width="120" Text="{Binding UnsafeRunThreshold, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"/>
          </StackPanel>
         </StackPanel>
        </Border>
        <Border Style="{StaticResource CardStyle}" Background="#FFF6FBFD">
         <StackPanel>
          <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.StartupSettings]}"/>
          <DockPanel Margin="0,12,0,0"><primitives:ToggleButton DockPanel.Dock="Left" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}"/><TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Strings[Hint.LaunchAtStartup]}"/></DockPanel>
          <DockPanel Margin="0,10,0,0"><primitives:ToggleButton DockPanel.Dock="Left" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding AutoStartMonitoringOnLaunch, Mode=TwoWay}"/><TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Strings[Hint.AutoStartMonitoringOnLaunch]}"/></DockPanel>
          <TextBlock Margin="0,14,0,0" FontSize="13" TextWrapping="Wrap" Text="{Binding StorageSummary}"/>
         </StackPanel>
        </Border>
       </UniformGrid>
       <Border Grid.Row="2" Style="{StaticResource CardStyle}" Background="#FFF8FBFD">
        <StackPanel>
         <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.DataLocations]}"/>
         <TextBlock Margin="0,10,0,0" FontSize="13" TextWrapping="Wrap" FontFamily="Consolas" Text="{Binding DataLocationSummary}"/>
         <WrapPanel Margin="0,14,0,0">
         <Button Content="{Binding Strings[Button.OpenProfilesDirectory]}" Command="{Binding OpenProfilesDirectoryCommand}" Background="#FF1E8FA3"/>
          <Button Content="{Binding Strings[Button.OpenDeviceStrategiesDirectory]}" Command="{Binding OpenDeviceStrategiesDirectoryCommand}" Background="#FF2E9AAE"/>
          <Button Content="{Binding Strings[Button.OpenRuntimeDirectory]}" Command="{Binding OpenRuntimeDirectoryCommand}" Background="#FF4E7080"/>
          <Button Content="{Binding Strings[Button.OpenLogsDirectory]}" Command="{Binding OpenLogsDirectoryCommand}" Background="#FF6A86B7"/>
          <Button Content="{Binding Strings[Button.OpenApplicationDirectory]}" Command="{Binding OpenApplicationDirectoryCommand}" Background="#FF9B6A18"/>
         </WrapPanel>
        </StackPanel>
       </Border>
       <Border Grid.Row="3" Style="{StaticResource CardStyle}" Background="#FFFCFDFC">
        <StackPanel>
         <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <StackPanel>
           <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Strings[Section.StatusCenter]}"/>
           <TextBlock Margin="0,10,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TitleBrush}" Text="{Binding StatusCenterSummary}"/>
           <TextBlock Margin="0,10,0,0" FontSize="13" TextWrapping="Wrap" Text="{Binding MonitoringStatus}"/>
          </StackPanel>
          <Button Grid.Column="1" Content="{Binding Strings[Button.ClearStatusCenter]}" Command="{Binding ClearStatusCenterCommand}" Background="#FF4E7080"/>
         </Grid>
         <ListBox Margin="0,16,0,0" Height="260" ItemsSource="{Binding StatusCenterItems}">
          <ListBox.ItemTemplate>
           <DataTemplate DataType="{x:Type viewModels:StatusCenterItemViewModel}">
            <Border Margin="0,0,0,10" Padding="12" Background="#FFF8FAFB" BorderBrush="#FFE3E8EC" BorderThickness="1" CornerRadius="12">
             <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="130"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <TextBlock FontFamily="Consolas" Text="{Binding Timestamp, StringFormat={}{0:MM-dd HH:mm:ss}}"/>
              <TextBlock Grid.Column="1" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding Source}"/>
              <Border Grid.Column="2" Padding="8,2" HorizontalAlignment="Left" CornerRadius="999">
               <Border.Style>
                <Style TargetType="Border">
                 <Setter Property="Background" Value="#FFE8F0F4"/>
                 <Style.Triggers>
                  <DataTrigger Binding="{Binding LevelKey}" Value="Success"><Setter Property="Background" Value="#FFE4F5E8"/></DataTrigger>
                  <DataTrigger Binding="{Binding LevelKey}" Value="Warning"><Setter Property="Background" Value="#FFFFF1D9"/></DataTrigger>
                  <DataTrigger Binding="{Binding LevelKey}" Value="Error"><Setter Property="Background" Value="#FFFBE1E4"/></DataTrigger>
                 </Style.Triggers>
                </Style>
               </Border.Style>
               <TextBlock FontWeight="SemiBold" Text="{Binding Level}"/>
              </Border>
              <TextBlock Grid.Column="3" TextWrapping="Wrap" Text="{Binding Message}"/>
             </Grid>
            </Border>
           </DataTemplate>
          </ListBox.ItemTemplate>
         </ListBox>
        </StackPanel>
       </Border>
      </Grid>
     </ScrollViewer>
    </TabItem>
   </TabControl>
  </Border>
 </Grid>
</Window>
